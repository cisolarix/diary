.date-label {
  color: #667eea;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}

.editor {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  min-height: 420rpx;
  padding: 28rpx;
  width: 100%;
}

.meta {
  color: #999;
  font-size: 24rpx;
  margin-top: 16rpx;
  text-align: right;
}
