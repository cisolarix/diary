.header {
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
}

.subtitle {
  color: #999;
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.section-title {
  color: #666;
  font-size: 26rpx;
  margin: 40rpx 0 16rpx;
}

.diary-date {
  color: #667eea;
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.diary-content {
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  line-height: 1.6;
  overflow: hidden;
}

.diary-item:active {
  opacity: 0.85;
}
