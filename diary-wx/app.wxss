page {
  background: #f7f8fa;
  color: #1a1a1a;
  font-size: 28rpx;
}

.container {
  padding: 32rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  margin-top: 24rpx;
}

.primary-btn[disabled] {
  opacity: 0.6;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.empty {
  color: #999;
  padding: 120rpx 0;
  text-align: center;
}
