# Copy to .env and adjust values (do not commit .env)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=diary
DB_USER=postgres
DB_PASSWORD=your-postgres-password

# WeChat mini-program credentials (leave empty for local dev-login mode)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_DEV_MODE=true

# JWT secret — change in production (at least 32 characters)
DIARY_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
